:enablesEvaluationBy rdf:type owl:ObjectProperty;
	 rdfs:label "enablesEvaluationBy"@en;
	 rdfs:comment "The post-market monitoring system enables the provider to evaluate continuous compliance of AI systems."@en;
	 schema:domainIncludes :post-market_monitoring_system;
	 schema:rangeIncludes :provider;
	 prov:wasAttributedTo "LLM".

:collectsDataFrom rdf:type owl:ObjectProperty;
	 rdfs:label "collectsDataFrom"@en;
	 rdfs:comment "The post-market monitoring system collects data from deployers on AI system performance."@en;
	 schema:domainIncludes :post-market_monitoring_system;
	 schema:rangeIncludes :deployer;
	 prov:wasAttributedTo "LLM".

:monitorsUseOf rdf:type owl:ObjectProperty;
	 rdfs:label "monitorsUseOf"@en;
	 rdfs:comment "The post-market monitoring system monitors the use of AI systems."@en;
	 schema:domainIncludes :post-market_monitoring_system;
	 schema:rangeIncludes :AI_system;
	 prov:wasAttributedTo "LLM".

:designates rdf:type owl:ObjectProperty;
	 rdfs:label "designates"@en;
	 rdfs:comment "The AI Office may designate a general-purpose AI model as presenting systemic risks."@en;
	 schema:domainIncludes :AI_Office;
	 schema:rangeIncludes :Systemic_Risk_General-Purpose_AI_Model;
	 prov:wasAttributedTo "LLM".

