@prefix : <http://example.org/eu-ai-act#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix airo: <https://w3id.org/airo#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix terms: <http://purl.org/dc/terms/> .
@prefix prov: <https://www.w3.org/TR/prov-o/> .
@prefix schema: <http://schema.org/> .

#################################################################
# Classes description
#################################################################

:AI_system rdf:type owl:Class;
	 rdfs:label "AI system"@en;
	 rdfs:comment " means amachine-based system that is designed to operate with varying levels of autonomy and that may exhibit adaptiveness after deployment, and that, for explicit or implicit objectives, infers, from the input it receives, how to generate outputs such as predictions, content, recommendations, or decisions that can influence physical or virtual environments;"@en;
	 prov:wasAttributedTo 'document'.

:risk rdf:type owl:Class;
	 rdfs:label "risk"@en;
	 rdfs:comment " means the combination of the probability of an occurrence of harm and the severity of that harm;"@en;
	 prov:wasAttributedTo 'document'.

:provider rdf:type owl:Class;
	 rdfs:label "provider"@en;
	 rdfs:comment " means anatural or legal person, public authority, agency or other body that develops an AI system or ageneral-purpose AI model or that has an AI system or ageneral-purpose AI model developed and places it on the market or puts the AI system into service under its own name or trademark, whether for payment or free of charge;"@en;
	 prov:wasAttributedTo 'document'.

:deployer rdf:type owl:Class;
	 rdfs:label "deployer"@en;
	 rdfs:comment " means anatural or legal person, public authority, agency or other body using an AI system under its authority except where the AI system is used in the course of apersonal non-professional activity;"@en;
	 prov:wasAttributedTo 'document'.

:authorised_representative rdf:type owl:Class;
	 rdfs:label "authorised representative"@en;
	 rdfs:comment " means anatural or legal person located or established in the Union who has received and accepted awritten mandate from aprovider of an AI system or ageneral-purpose AI model to, respectively, perform and carry out on its behalf the obligations and procedures established by this Regulation;"@en;
	 prov:wasAttributedTo 'document'.

:importer rdf:type owl:Class;
	 rdfs:label "importer"@en;
	 rdfs:comment " means anatural or legal person located or established in the Union that places on the market an AI system that bears the name or trademark of anatural or legal person established in athird country;"@en;
	 prov:wasAttributedTo 'document'.

:distributor rdf:type owl:Class;
	 rdfs:label "distributor"@en;
	 rdfs:comment " means anatural or legal person in the supply chain, other than the provider or the importer, that makes an AI system available on the Union market;"@en;
	 prov:wasAttributedTo 'document'.

:operator rdf:type owl:Class;
	 rdfs:label "operator"@en;
	 rdfs:comment " means aprovider, product manufacturer, deployer, authorised representative, importer or distributor;"@en;
	 prov:wasAttributedTo 'document'.

:placing_on_the_market rdf:type owl:Class;
	 rdfs:label "placing on the market"@en;
	 rdfs:comment " means the first making available of an AI system or ageneral-purpose AI model on the Union market;"@en;
	 prov:wasAttributedTo 'document'.

:making_available_on_the_market rdf:type owl:Class;
	 rdfs:label "making available on the market"@en;
	 rdfs:comment " means the supply of an AI system or ageneral-purpose AI model for distribution or use on the Union market in the course of acommercial activity, whether in return for payment or free of charge;"@en;
	 prov:wasAttributedTo 'document'.

:putting_into_service rdf:type owl:Class;
	 rdfs:label "putting into service"@en;
	 rdfs:comment " means the supply of an AI system for first use directly to the deployer or for own use in the Union for its intended purpose;"@en;
	 prov:wasAttributedTo 'document'.

:intended_purpose rdf:type owl:Class;
	 rdfs:label "intended purpose"@en;
	 rdfs:comment " means the use for which an AI system is intended by the provider, including the specific context and conditions of use, as specified in the information supplied by the provider in the instructions for use, promotional or sales materials and statements, as well as in the technical documentation;"@en;
	 prov:wasAttributedTo 'document'.

:reasonably_foreseeable_misuse rdf:type owl:Class;
	 rdfs:label "reasonably foreseeable misuse"@en;
	 rdfs:comment " means the use of an AI system in away that is not in accordance with its intended purpose, but which may result from reasonably foreseeable human behaviour or interaction with other systems, including other AI systems;"@en;
	 prov:wasAttributedTo 'document'.

:safety_component rdf:type owl:Class;
	 rdfs:label "safety component"@en;
	 rdfs:comment " means acomponent of aproduct or of an AI system which fulfils asafety function for that product or AI system, or the failure or malfunctioning of which endangers the health and safety of persons or property;"@en;
	 prov:wasAttributedTo 'document'.

:instructions_for_use rdf:type owl:Class;
	 rdfs:label "instructions for use"@en;
	 rdfs:comment " means the information provided by the provider to inform the deployer of, in particular, an AI system’s intended purpose and proper use;"@en;
	 prov:wasAttributedTo 'document'.

:recall_of_an_AI_system rdf:type owl:Class;
	 rdfs:label "recall of an AI system"@en;
	 rdfs:comment " means any measure aiming to achieve the return to the provider or taking out of service or disabling the use of an AI system made available to deployers;"@en;
	 prov:wasAttributedTo 'document'.

:withdrawal_of_an_AI_system rdf:type owl:Class;
	 rdfs:label "withdrawal of an AI system"@en;
	 rdfs:comment " means any measure aiming to prevent an AI system in the supply chain being made available on the market;"@en;
	 prov:wasAttributedTo 'document'.

:performance_of_an_AI_system rdf:type owl:Class;
	 rdfs:label "performance of an AI system"@en;
	 rdfs:comment " means the ability of an AI system to achieve its intended purpose;"@en;
	 prov:wasAttributedTo 'document'.

:notifying_authority rdf:type owl:Class;
	 rdfs:label "notifying authority"@en;
	 rdfs:comment " means the national authority responsible for setting up and carrying out the necessary procedures for the assessment, designation and notification of conformity assessment bodies and for their monitoring;"@en;
	 prov:wasAttributedTo 'document'.

:conformity_assessment rdf:type owl:Class;
	 rdfs:label "conformity assessment"@en;
	 rdfs:comment " means the process of demonstrating whether the requirements set out in ChapterIII, Section2 relating to ahigh-risk AI system have been fulfilled;"@en;
	 prov:wasAttributedTo 'document'.

:conformity_assessment_body rdf:type owl:Class;
	 rdfs:label "conformity assessment body"@en;
	 rdfs:comment " means abody that performs third-party conformity assessment activities, including testing, certification and inspection;"@en;
	 prov:wasAttributedTo 'document'.

:notified_body rdf:type owl:Class;
	 rdfs:label "notified body"@en;
	 rdfs:comment " means aconformity assessment body notified in accordance with this Regulation and other relevant Union harmonisation legislation;"@en;
	 prov:wasAttributedTo 'document'.

:substantial_modification rdf:type owl:Class;
	 rdfs:label "substantial modification"@en;
	 rdfs:comment " means achange to an AI system after its placing on the market or putting into service which is not foreseen or planned in the initial conformity assessment carried out by the provider and as aresult of which the compliance of the AI system with the requirements set out in ChapterIII, Section2 is affected or results in amodification to the intended purpose for which the AI system has been assessed;"@en;
	 prov:wasAttributedTo 'document'.

:CE_marking rdf:type owl:Class;
	 rdfs:label "CE marking"@en;
	 rdfs:comment " means amarking by which aprovider indicates that an AI system is in conformity with the requirements set out in ChapterIII, Section2 and other applicable Union harmonisation legislation providing for its affixing;"@en;
	 prov:wasAttributedTo 'document'.

:post-market_monitoring_system rdf:type owl:Class;
	 rdfs:label "post-market monitoring system"@en;
	 rdfs:comment " means all activities carried out by providers of AI systems to collect and review experience gained from the use of AI systems they place on the market or put into service for the purpose of identifying any need to immediately apply any necessary corrective or preventive actions;"@en;
	 prov:wasAttributedTo 'document'.

:market_surveillance_authority rdf:type owl:Class;
	 rdfs:label "market surveillance authority"@en;
	 rdfs:comment " means the national authority carrying out the activities and taking the measures pursuant to Regulation (EU) 2019/1020;"@en;
	 prov:wasAttributedTo 'document'.

:harmonised_standard rdf:type owl:Class;
	 rdfs:label "harmonised standard"@en;
	 rdfs:comment " means aharmonised standard as defined in Article2(1), point (c), of Regulation (EU) No1025/2012;"@en;
	 prov:wasAttributedTo 'document'.

:common_specification rdf:type owl:Class;
	 rdfs:label "common specification"@en;
	 rdfs:comment " means aset of technical specifications as defined in Article2, point (4) of Regulation (EU) No1025/2012, providing means to comply with certain requirements established under this Regulation;"@en;
	 prov:wasAttributedTo 'document'.

:training_data rdf:type owl:Class;
	 rdfs:label "training data"@en;
	 rdfs:comment " means data used for training an AI system through fitting its learnable parameters;"@en;
	 prov:wasAttributedTo 'document'.

:validation_data rdf:type owl:Class;
	 rdfs:label "validation data"@en;
	 rdfs:comment " means data used for providing an evaluation of the trained AI system and for tuning its non-learnable parameters and its learning process in order, inter alia, to prevent underfitting or overfitting;"@en;
	 prov:wasAttributedTo 'document'.

:validation_data_set rdf:type owl:Class;
	 rdfs:label "validation data set"@en;
	 rdfs:comment " means aseparate data set or part of the training data set, either as afixed or variable split;"@en;
	 prov:wasAttributedTo 'document'.

:testing_data rdf:type owl:Class;
	 rdfs:label "testing data"@en;
	 rdfs:comment " means data used for providing an independent evaluation of the AI system in order to confirm the expected performance of that system before its placing on the market or putting into service;"@en;
	 prov:wasAttributedTo 'document'.

:input_data rdf:type owl:Class;
	 rdfs:label "input data"@en;
	 rdfs:comment " means data provided to or directly acquired by an AI system on the basis of which the system produces an output;"@en;
	 prov:wasAttributedTo 'document'.

:biometric_data rdf:type owl:Class;
	 rdfs:label "biometric data"@en;
	 rdfs:comment " means personal data resulting from specific technical processing relating to the physical, physiological or behavioural characteristics of anatural person, such as facial images or dactyloscopic data;"@en;
	 prov:wasAttributedTo 'document'.

:biometric_identification rdf:type owl:Class;
	 rdfs:label "biometric identification"@en;
	 rdfs:comment " means the automated recognition of physical, physiological, behavioural, or psychological human features for the purpose of establishing the identity of anatural person by comparing biometric data of that individual to biometric data of individuals stored in adatabase;"@en;
	 prov:wasAttributedTo 'document'.

:biometric_verification rdf:type owl:Class;
	 rdfs:label "biometric verification"@en;
	 rdfs:comment " means the automated, one-to-one verification, including authentication, of the identity of natural persons by comparing their biometric data to previously provided biometric data;"@en;
	 prov:wasAttributedTo 'document'.

:special_categories_of_personal_data rdf:type owl:Class;
	 rdfs:label "special categories of personal data"@en;
	 rdfs:comment " means the categories of personal data referred to in Article9(1) of Regulation (EU) 2016/679, Article10 of Directive (EU) 2016/680 and Article10(1) of Regulation (EU) 2018/1725;"@en;
	 prov:wasAttributedTo 'document'.

:sensitive_operational_data rdf:type owl:Class;
	 rdfs:label "sensitive operational data"@en;
	 rdfs:comment " means operational data related to activities of prevention, detection, investigation or prosecution of criminal offences, the disclosure of which could jeopardise the integrity of criminal proceedings;"@en;
	 prov:wasAttributedTo 'document'.

:emotion_recognition_system rdf:type owl:Class;
	 rdfs:label "emotion recognition system"@en;
	 rdfs:comment " means an AI system for the purpose of identifying or inferring emotions or intentions of natural persons on the basis of their biometric data;"@en;
	 prov:wasAttributedTo 'document'.

:biometric_categorisation_system rdf:type owl:Class;
	 rdfs:label "biometric categorisation system"@en;
	 rdfs:comment " means an AI system for the purpose of assigning natural persons to specific categories on the basis of their biometric data, unless it is ancillary to another commercial service and strictly necessary for objective technical reasons;"@en;
	 prov:wasAttributedTo 'document'.

:remote_biometric_identification_system rdf:type owl:Class;
	 rdfs:label "remote biometric identification system"@en;
	 rdfs:comment " means an AI system for the purpose of identifying natural persons, without their active involvement, typically at adistance through the comparison of aperson’s biometric data with the biometric data contained in areference database;"@en;
	 prov:wasAttributedTo 'document'.

:real-time_remote_biometric_identification_system rdf:type owl:Class;
	 rdfs:label "real-time remote biometric identification system"@en;
	 rdfs:comment " means aremote biometric identification system, whereby the capturing of biometric data, the comparison and the identification all occur without asignificant delay, comprising not only instant identification, but also limited short delays in order to avoid circumvention;"@en;
	 prov:wasAttributedTo 'document'.

:post-remote_biometric_identification_system rdf:type owl:Class;
	 rdfs:label "post-remote biometric identification system"@en;
	 rdfs:comment " means aremote biometric identification system other than areal-time remote biometric identification system;"@en;
	 prov:wasAttributedTo 'document'.

:publicly_accessible_space rdf:type owl:Class;
	 rdfs:label "publicly accessible space"@en;
	 rdfs:comment " means any publicly or privately owned physical place accessible to an undetermined number of natural persons, regardless of whether certain conditions for access may apply, and regardless of the potential capacity restrictions;"@en;
	 prov:wasAttributedTo 'document'.

:law_enforcement_authority rdf:type owl:Class;
	 rdfs:label "law enforcement authority"@en;
	 rdfs:comment " means: any public authority competent for the prevention, investigation, detection or prosecution of criminal offences or the execution of criminal penalties, including the safeguarding against and the prevention of threats to public security; or any other body or entity entrusted by Member State law to exercise public authority and public powers for the purposes of the prevention, investigation, detection or prosecution of criminal offences or the execution of criminal penalties, including the safeguarding against and the prevention of threats to public security;"@en;
	 prov:wasAttributedTo 'document'.

:law_enforcement rdf:type owl:Class;
	 rdfs:label "law enforcement"@en;
	 rdfs:comment " means activities carried out by law enforcement authorities or on their behalf for the prevention, investigation, detection or prosecution of criminal offences or the execution of criminal penalties, including safeguarding against and preventing threats to public security;"@en;
	 prov:wasAttributedTo 'document'.

:AI_Office rdf:type owl:Class;
	 rdfs:label "AI Office"@en;
	 rdfs:comment " means the Commission’s function of contributing to the implementation, monitoring and supervision of AI systems and general-purpose AI models, and AI governance, provided for in Commission Decision of 24January 2024; references in this Regulation to the AI Office shall be construed as references to the Commission;"@en;
	 prov:wasAttributedTo 'document'.

:national_competent_authority rdf:type owl:Class;
	 rdfs:label "national competent authority"@en;
	 rdfs:comment " means anotifying authority or amarket surveillance authority; as regards AI systems put into service or used by Union institutions, agencies, offices and bodies, references to national competent authorities or market surveillance authorities in this Regulation shall be construed as references to the European Data Protection Supervisor;"@en;
	 prov:wasAttributedTo 'document'.

:serious_incident rdf:type owl:Class;
	 rdfs:label "serious incident"@en;
	 rdfs:comment " means an incident or malfunctioning of an AI system that directly or indirectly leads to any of the following: the death of aperson, or serious harm to aperson’s health; a serious and irreversible disruption of the management or operation of critical infrastructure; the infringement of obligations under Union law intended to protect fundamental rights; serious harm to property or the environment;"@en;
	 prov:wasAttributedTo 'document'.

:personal_data rdf:type owl:Class;
	 rdfs:label "personal data"@en;
	 rdfs:comment " means personal data as defined in Article4, point (1), of Regulation(EU)2016/679;"@en;
	 prov:wasAttributedTo 'document'.

:non-personal_data rdf:type owl:Class;
	 rdfs:label "non-personal data"@en;
	 rdfs:comment " means data other than personal data as defined in Article4, point (1), of Regulation (EU) 2016/679;"@en;
	 prov:wasAttributedTo 'document'.

:profiling rdf:type owl:Class;
	 rdfs:label "profiling"@en;
	 rdfs:comment " means profiling as defined in Article4, point (4), of Regulation (EU) 2016/679;"@en;
	 prov:wasAttributedTo 'document'.

:real-world_testing_plan rdf:type owl:Class;
	 rdfs:label "real-world testing plan"@en;
	 rdfs:comment " means adocument that describes the objectives, methodology, geographical, population and temporal scope, monitoring, organisation and conduct of testing in real-world conditions;"@en;
	 prov:wasAttributedTo 'document'.

:sandbox_plan rdf:type owl:Class;
	 rdfs:label "sandbox plan"@en;
	 rdfs:comment " means adocument agreed between the participating provider and the competent authority describing the objectives, conditions, timeframe, methodology and requirements for the activities carried out within the sandbox;"@en;
	 prov:wasAttributedTo 'document'.

:AI_regulatory_sandbox rdf:type owl:Class;
	 rdfs:label "AI regulatory sandbox"@en;
	 rdfs:comment " means acontrolled framework set up by acompetent authority which offers providers or prospective providers of AI systems the possibility to develop, train, validate and test, where appropriate in real-world conditions, an innovative AI system, pursuant to asandbox plan for alimited time under regulatory supervision;"@en;
	 prov:wasAttributedTo 'document'.

:AI_literacy rdf:type owl:Class;
	 rdfs:label "AI literacy"@en;
	 rdfs:comment " means skills, knowledge and understanding that allow providers, deployers and affected persons, taking into account their respective rights and obligations in the context of this Regulation, to make an informed deployment of AI systems, as well as to gain awareness about the opportunities and risks of AI and possible harm it can cause;"@en;
	 prov:wasAttributedTo 'document'.

:testing_in_real-world_conditions rdf:type owl:Class;
	 rdfs:label "testing in real-world conditions"@en;
	 rdfs:comment " means the temporary testing of an AI system for its intended purpose in real-world conditions outside alaboratory or otherwise simulated environment, with aview to gathering reliable and robust data and to assessing and verifying the conformity of the AI system with the requirements of this Regulation and it does not qualify as placing the AI system on the market or putting it into service within the meaning of this Regulation, provided that all the conditions laid down in Article57 or 60 are fulfilled;"@en;
	 prov:wasAttributedTo 'document'.

:subject rdf:type owl:Class;
	 rdfs:label "subject"@en;
	 rdfs:comment ", for the purpose of real-world testing, means anatural person who participates in testing in real-world conditions;"@en;
	 prov:wasAttributedTo 'document'.

:informed_consent rdf:type owl:Class;
	 rdfs:label "informed consent"@en;
	 rdfs:comment " means asubject’s freely given, specific, unambiguous and voluntary expression of his or her willingness to participate in aparticular testing in real-world conditions, after having been informed of all aspects of the testing that are relevant to the subject’s decision to participate;"@en;
	 prov:wasAttributedTo 'document'.

:deep_fake rdf:type owl:Class;
	 rdfs:label "deep fake"@en;
	 rdfs:comment " means AI-generated or manipulated image, audio or video content that resembles existing persons, objects, places, entities or events and would falsely appear to aperson to be authentic or truthful;"@en;
	 prov:wasAttributedTo 'document'.

:widespread_infringement rdf:type owl:Class;
	 rdfs:label "widespread infringement"@en;
	 rdfs:comment " means any act or omission contrary to Union law protecting the interest of individuals, which: has harmed or is likely to harm the collective interests of individuals residing in at least two Member States other than the Member State in which: the act or omission originated or took place; the provider concerned, or, where applicable, its authorised representative is located or established; or the deployer is established, when the infringement is committed by the deployer; has caused, causes or is likely to cause harm to the collective interests of individuals and has common features, including the same unlawful practice or the same interest being infringed, and is occurring concurrently, committed by the same operator, in at least three Member States;"@en;
	 prov:wasAttributedTo 'document'.

:critical_infrastructure rdf:type owl:Class;
	 rdfs:label "critical infrastructure"@en;
	 rdfs:comment " means critical infrastructure as defined in Article2, point (4), of Directive (EU)2022/2557;"@en;
	 prov:wasAttributedTo 'document'.

:general-purpose_AI_model rdf:type owl:Class;
	 rdfs:label "general-purpose AI model"@en;
	 rdfs:comment " means an AI model, including where such an AI model is trained with alarge amount of data using self-supervision at scale, that displays significant generality and is capable of competently performing awide range of distinct tasks regardless of the way the model is placed on the market and that can be integrated into avariety of downstream systems or applications, except AI models that are used for research, development or prototyping activities before they are placed on the market;"@en;
	 prov:wasAttributedTo 'document'.

:high-impact_capabilities rdf:type owl:Class;
	 rdfs:label "high-impact capabilities"@en;
	 rdfs:comment " means capabilities that match or exceed the capabilities recorded in the most advanced general-purpose AI models;"@en;
	 prov:wasAttributedTo 'document'.

:systemic_risk rdf:type owl:Class;
	 rdfs:label "systemic risk"@en;
	 rdfs:comment " means arisk that is specific to the high-impact capabilities of general-purpose AI models, having asignificant impact on the Union market due to their reach, or due to actual or reasonably foreseeable negative effects on public health, safety, public security, fundamental rights, or the society as awhole, that can be propagated at scale across the value chain;"@en;
	 prov:wasAttributedTo 'document'.

:general-purpose_AI_system rdf:type owl:Class;
	 rdfs:label "general-purpose AI system"@en;
	 rdfs:comment " means an AI system which is based on ageneral-purpose AI model and which has the capability to serve avariety of purposes, both for direct use as well as for integration in other AI systems;"@en;
	 prov:wasAttributedTo 'document'.

:floating-point_operation rdf:type owl:Class;
	 rdfs:label "floating-point operation"@en;
	 rdfs:comment " means any mathematical operation or assignment involving floating-point numbers, which are asubset of the real numbers typically represented on computers by an integer of fixed precision scaled by an integer exponent of afixed base;"@en;
	 prov:wasAttributedTo 'document'.

:downstream_provider rdf:type owl:Class;
	 rdfs:label "downstream provider"@en;
	 rdfs:comment " means aprovider of an AI system, including ageneral-purpose AI system, which integrates an AI model, regardless of whether the AI model is provided by themselves and vertically integrated or provided by another entity based on contractual relations."@en;
	 prov:wasAttributedTo 'document'.

:Prohibited_AI_Practice rdf:type owl:Class;
	 rdfs:label "Prohibited AI Practice"@en;
	 rdfs:comment "A status condition assigned to an AI system or activity that is explicitly forbidden under the Regulation, triggering immediate legal consequences such as withdrawal or fines."@en;
	 prov:wasAttributedTo 'LLM'.

:Affected_Person_AI_System_Use rdf:type owl:Class;
	 rdfs:label "Affected Person (AI System Use)"@en;
	 rdfs:comment "A functional role describing a natural person located in the Union who is directly or indirectly influenced by an AI system's operation or output, and who may be entitled to specific rights or protections under this Regulation."@en;
	 prov:wasAttributedTo 'LLM'.

:Administrative_Fine_GPAI_Provider rdf:type owl:Class;
	 rdfs:label "Administrative Fine (GPAI Provider)"@en;
	 rdfs:comment "A legal consequence for providers of general-purpose AI models who negligently or intentionally infringe specific provisions, fail to comply with information requests, or deny access for evaluation, subject to fines up to 3% of turnover or EUR 15,000,000."@en;
	 prov:wasAttributedTo 'LLM'.

:AI_Component_Supplier rdf:type owl:Class;
	 rdfs:label "AI Component Supplier"@en;
	 rdfs:comment "A functional role describing any third party that supplies an AI system, tools, services, components, or processes that are used or integrated into a high-risk AI system, and is obligated by written agreement to provide necessary information and assistance to the provider."@en;
	 prov:wasAttributedTo 'LLM'.

:Copyright_Compliance_Obligation_AI_Model_Provider rdf:type owl:Class;
	 rdfs:label "Copyright Compliance Obligation (AI Model Provider)"@en;
	 rdfs:comment "A mandatory legal duty for providers of general-purpose AI models to implement a policy that ensures compliance with Union copyright and related rights law, including identifying and respecting rights reservations in training data."@en;
	 prov:wasAttributedTo 'LLM'.

:Systemic_Risk_General-Purpose_AI_Model rdf:type owl:Class;
	 rdfs:label "Systemic Risk General-Purpose AI Model"@en;
	 rdfs:comment "A classification for a general-purpose AI model that meets specific criteria (e.g., high-impact capabilities, computational power) and is deemed to pose significant, widespread risks, triggering additional obligations for its provider."@en;
	 prov:wasAttributedTo 'LLM'.

:Right_to_AI_Explanation rdf:type owl:Class;
	 rdfs:label "Right to AI Explanation"@en;
	 rdfs:comment "A fundamental legal right for an affected person to receive clear and meaningful explanations from a deployer regarding the role of a high-risk AI system in a decision that produces legal effects or significantly impacts them adversely."@en;
	 prov:wasAttributedTo 'LLM'.

:Public_Service_Deployer rdf:type owl:Class;
	 rdfs:label "Public Service Deployer"@en;
	 rdfs:comment "A specific functional role for a deployer that is a body governed by public law or a private entity providing public services, subject to the obligation of performing a Fundamental Rights Impact Assessment for certain high-risk AI systems."@en;
	 prov:wasAttributedTo 'LLM'.

:Real-World_Testing_Consent_Subject rdf:type owl:Class;
	 rdfs:label "Real-World Testing Consent (Subject)"@en;
	 rdfs:comment "The legally required, freely given, specific, unambiguous, and voluntary expression of willingness by a natural person to participate in the testing of an AI system in real-world conditions, after being fully informed of all relevant aspects."@en;
	 prov:wasAttributedTo 'LLM'.

:Synthetic_Content_AI_System rdf:type owl:Class;
	 rdfs:label "Synthetic Content AI System"@en;
	 rdfs:comment "A type of AI system that generates or manipulates audio, image, video, or text content and is subject to transparency obligations, specifically requiring its outputs to be marked as artificially generated or manipulated in a machine-readable format."@en;
	 prov:wasAttributedTo 'LLM'.

:Authorised_Derogation_Public_Interest rdf:type owl:Class;
	 rdfs:label "Authorised Derogation (Public Interest)"@en;
	 rdfs:comment "A temporary legal status granted by a market surveillance authority, allowing the placing on the market or putting into service of specific high-risk AI systems without full conformity assessment for exceptional public security, health, or environmental protection reasons, subject to strict conditions."@en;
	 prov:wasAttributedTo 'LLM'.

:Presumption_of_Conformity_Status rdf:type owl:Class;
	 rdfs:label "Presumption of Conformity Status"@en;
	 rdfs:comment "A legal status where an AI system or body is legally presumed to comply with specific regulatory requirements if it conforms to harmonised standards, common specifications, or other certified criteria, potentially shifting the burden of proof in compliance arguments."@en;
	 prov:wasAttributedTo 'LLM'.

:Fundamental_Rights_Impact_Assessment rdf:type owl:Class;
	 rdfs:label "Fundamental Rights Impact Assessment"@en;
	 rdfs:comment "A mandatory procedural step that certain public service deployers must perform to evaluate the potential impact of a high-risk AI system on fundamental rights prior to its deployment, influencing the legality of its use."@en;
	 prov:wasAttributedTo 'LLM'.

:Risk-Presenting_AI_System_Status rdf:type owl:Class;
	 rdfs:label "Risk-Presenting AI System Status"@en;
	 rdfs:comment "A status condition for any AI system that poses a risk to the health or safety, or fundamental rights of persons, triggering investigation by market surveillance authorities and potentially leading to mandatory corrective actions or market restrictions."@en;
	 prov:wasAttributedTo 'LLM'.

:Administrative_Fine_Prohibited_AI_Practice rdf:type owl:Class;
	 rdfs:label "Administrative Fine (Prohibited AI Practice)"@en;
	 rdfs:comment "A severe legal consequence for non-compliance with prohibited AI practices, involving administrative fines up to EUR 35,000,000 or 7% of worldwide annual turnover, whichever is higher."@en;
	 prov:wasAttributedTo 'LLM'.

:AI_Regulatory_Sandbox_Framework rdf:type owl:Class;
	 rdfs:label "AI Regulatory Sandbox Framework"@en;
	 rdfs:comment "A controlled legal and technical environment established by a competent authority to facilitate the development, training, validation, and testing of innovative AI systems under regulatory supervision for a limited time, offering specific legal flexibilities."@en;
	 prov:wasAttributedTo 'LLM'.

:Notified_Body_Independence_Status rdf:type owl:Class;
	 rdfs:label "Notified Body Independence Status"@en;
	 rdfs:comment "A critical status condition requiring a notified body to be free from direct involvement or economic interest in the design, development, marketing, or use of the AI systems it assesses, ensuring impartiality in conformity assessment."@en;
	 prov:wasAttributedTo 'LLM'.

:AI_Scientific_Panel_Expert rdf:type owl:Class;
	 rdfs:label "AI Scientific Panel Expert"@en;
	 rdfs:comment "A functional role for an independent expert appointed by the Commission to provide scientific or technical advice to the AI Office, particularly concerning systemic risks of general-purpose AI models and enforcement activities."@en;
	 prov:wasAttributedTo 'LLM'.

:Union_Market_Operator_Third_Country rdf:type owl:Class;
	 rdfs:label "Union Market Operator (Third Country)"@en;
	 rdfs:comment "A functional role describing any provider or deployer of an AI system established or located in a third country, whose AI system's output is used in the Union, thereby subjecting them to the Regulation's obligations."@en;
	 prov:wasAttributedTo 'LLM'.

:Deemed_Provider rdf:type owl:Class;
	 rdfs:label "Deemed Provider"@en;
	 rdfs:comment "A legal status assigned to a distributor, importer, deployer, or other third-party who, by putting their name or trademark on an AI system, making a substantial modification, or changing its intended purpose, assumes the full obligations of a provider under this Regulation."@en;
	 prov:wasAttributedTo 'LLM'.

#################################################################
# Predicate description
#################################################################

:receives rdf:type owl:ObjectProperty;
	 rdfs:label "receives"@en;
	 rdfs:comment "An AI system takes in input data to generate outputs."@en;
	 schema:domainIncludes :AI_system,
		:deployer;
	 schema:rangeIncludes :Deployers_receive_instructions_for_use_for_an_AI_system,
		:input_data;
	 prov:wasAttributedTo "LLM".

:uses rdf:type owl:ObjectProperty;
	 rdfs:label "uses"@en;
	 rdfs:comment "A deployer uses an AI system under its authority."@en;
	 schema:domainIncludes :AI_system,
		:Union_Market_Operator_Third_Country,
		:deployer;
	 schema:rangeIncludes :biometric_data,
		:A_deployer_uses_an_AI_system_under_its_authority,
		:Union_Market_Operators_Third_Country_use_AI_systems_where_the_output_is_used_in_the_Union;
	 prov:wasAttributedTo "LLM".

:isA rdf:type owl:ObjectProperty;
	 rdfs:label "isA"@en;
	 rdfs:comment "A post-remote biometric identification system is a specific type of remote biometric identification system."@en;
	 schema:domainIncludes :provider,
		:remote_biometric_identification_system,
		:emotion_recognition_system,
		:special_categories_of_personal_data,
		:systemic_risk,
		:general-purpose_AI_system,
		:importer,
		:authorised_representative,
		:Union_Market_Operator_Third_Country,
		:biometric_data,
		:biometric_categorisation_system,
		:post-remote_biometric_identification_system,
		:distributor,
		:deployer,
		:real-time_remote_biometric_identification_system,
		:Real-World_Testing_Consent_Subject,
		:notified_body;
	 schema:rangeIncludes :A_post-remote_biometric_identification_system_is_a_specific_type_of_remote_biometric_identification_system,
		:Special_categories_of_personal_data_are_a_subset_of_personal_data,
		:A_biometric_categorisation_system_is_a_specific_type_of_AI_system,
		:A_distributor_is_defined_as_a_type_of_operator,
		:Biometric_data_is_a_type_of_personal_data,
		:Deployers_established_in_a_third_country_whose_AI_system_output_is_used_in_the_Union_are_considered_Union_Market_Operators_Third_Country,
		:A_real-time_remote_biometric_identification_system_is_a_specific_type_of_remote_biometric_identification_system,
		:A_provider_is_defined_as_a_type_of_operator,
		:A_remote_biometric_identification_system_is_a_specific_type_of_AI_system,
		:Systemic_risk_is_a_specific_type_of_risk_typically_associated_with_high-impact_capabilities_of_general-purpose_AI_models,
		:A_deployer_is_defined_as_a_type_of_operator,
		:An_authorised_representative_is_defined_as_a_type_of_operator,
		:AI_system,
		:An_importer_is_defined_as_a_type_of_operator,
		:A_notified_body_is_a_type_of_conformity_assessment_body_that_has_been_officially_notified,
		:Providers_established_in_a_third_country_whose_AI_system_output_is_used_in_the_Union_are_considered_Union_Market_Operators_Third_Country,
		:An_emotion_recognition_system_is_a_specific_type_of_AI_system,
		:Real-world_testing_consent_is_a_specific_type_of_informed_consent;
	 prov:wasAttributedTo "LLM".

:poses rdf:type owl:ObjectProperty;
	 rdfs:label "poses"@en;
	 rdfs:comment "An AI system can pose risks to health, safety, or fundamental rights."@en;
	 schema:domainIncludes :AI_system;
	 schema:rangeIncludes :risk;
	 prov:wasAttributedTo "LLM".

:isUsedAs rdf:type owl:ObjectProperty;
	 rdfs:label "isUsedAs"@en;
	 rdfs:comment "An AI system can be intended for use as a safety component of a product."@en;
	 schema:domainIncludes :AI_system;
	 schema:rangeIncludes :safety_component;
	 prov:wasAttributedTo "LLM".

:accompaniedBy rdf:type owl:ObjectProperty;
